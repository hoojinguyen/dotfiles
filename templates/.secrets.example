# .secrets - Local environment variables and credentials
# Copy this file to ~/.secrets and populate your keys.
# DO NOT commit the actual ~/.secrets file or check it into Git.

# GitHub Personal Access Token (PAT)
export GITHUB_PERSONAL_ACCESS_TOKEN=""

# Context7 API Key
export CONTEXT7_API_KEY=""

# Stitch API Key
export STITCH_API_KEY=""

# Gemini API Key
export GEMINI_API_KEY=""

# OpenRouter API Key
export OPENROUTER_API_KEY=""
